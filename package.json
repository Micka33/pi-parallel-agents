{
  "name": "@micka33/pi-parallel-agents",
  "version": "0.1.0",
  "description": "Pi extension and lifecycle scripts for launching parallel Pi sub-agents.",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi",
    "agents",
    "parallel-agents"
  ],
  "files": [
    "dist",
    "src/prompts",
    "scripts",
    "schemas",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/**/*.test.mjs",
    "ci": "npm run typecheck && node --test tests/**/*.test.mjs"
  },
  "dependencies": {
    "@micka33/pi-tasks": "^1.2.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^24.0.0",
    "typebox": "^1.1.38",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pi": {
    "extensions": [
      "./dist/src/parallel-agents.js"
    ],
    "skills": [
      "./skills"
    ]
  }
}
