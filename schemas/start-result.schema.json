{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ParallelAgentStartResult",
  "type": "object",
  "required": ["agentId", "displayName", "workspaceMode", "accessMode", "cwd", "model", "thinking", "status"],
  "properties": {
    "agentId": { "type": "string" },
    "displayName": { "type": "string" },
    "pid": { "type": ["integer", "null"] },
    "workspaceMode": { "enum": ["worktree", "current"] },
    "accessMode": { "enum": ["read_only", "write"] },
    "cwd": { "type": "string" },
    "provider": { "type": ["string", "null"] },
    "model": { "type": "string" },
    "thinking": { "type": "string" },
    "branchName": { "type": ["string", "null"] },
    "worktreePath": { "type": ["string", "null"] },
    "sessionId": { "type": ["string", "null"] },
    "sessionFile": { "type": ["string", "null"] },
    "status": { "enum": ["starting", "running", "waiting", "stopped", "crashed", "done", "cleaned"] }
  },
  "additionalProperties": false
}
